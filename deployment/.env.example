# Copy to `.env` and adjust as needed: `cp .env.example .env`
# docker compose reads this file automatically.

# ── Image tags ────────────────────────────────────────────────────────────────
ACS_TAG=26.1.0
TRANSFORM_TAG=5.4.2
POSTGRES_TAG=17.9
SOLR_TAG=2.0.20
ACTIVEMQ_TAG=6.2.6-jre17-rockylinux8
TRAEFIK_TAG=3.6

# ── Memory limits ───────────────────────────────────────────────────────────
# Stack needs ~7 GB total. Lower ALFRESCO_MEM / SOLR_MEM on constrained hosts,
# but ACS below ~1.5 GB will be slow to start.
ALFRESCO_MEM=1900m
TRANSFORM_MEM=1536m
POSTGRES_MEM=512m
SOLR_MEM=2g
ACTIVEMQ_MEM=1g
ACA_MEM=256m
PROXY_MEM=256m
